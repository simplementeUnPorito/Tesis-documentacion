<mxfile host="Electron" agent="Codex">
  <diagram id="psoc-calibration-flow" name="Foreground calibration flow">
    <mxGraphModel dx="1768" dy="1051" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="1250" math="1" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="start" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" value="Boot, PGA-gain change,&#xa;or calibration command" vertex="1">
          <mxGeometry height="80" width="200" x="100" y="215" as="geometry" />
        </mxCell>
        <mxCell id="load" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="Load EEPROM record for&#xa;selected PGA gain" vertex="1">
          <mxGeometry height="70" width="260" x="370" y="220" as="geometry" />
        </mxCell>
        <mxCell id="0vFOy6FI1LJlk_BVGu9a-1" edge="1" parent="1" source="validrecord" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="applystored">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="0vFOy6FI1LJlk_BVGu9a-2" edge="1" parent="1" source="validrecord" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" target="seed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="validrecord" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" value="Valid record&#xa;and CRC?" vertex="1">
          <mxGeometry height="90" width="180" x="410" y="325" as="geometry" />
        </mxCell>
        <mxCell id="0vFOy6FI1LJlk_BVGu9a-4" edge="1" parent="1" source="applystored" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" target="verifycfg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="applystored" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" value="Apply stored four-DAC code set" vertex="1">
          <mxGeometry height="65" width="140" x="645" y="337.5" as="geometry" />
        </mxCell>
        <mxCell id="0vFOy6FI1LJlk_BVGu9a-5" edge="1" parent="1" source="seed" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="verifycfg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="seed" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" value="Apply safe nominal DAC seeds" vertex="1">
          <mxGeometry height="65" width="140" x="215" y="337.5" as="geometry" />
        </mxCell>
        <mxCell id="verifycfg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" value="Configure AMux + ADC + DFB for&#xa;rapid offset verification" vertex="1">
          <mxGeometry height="70" width="290" x="355" y="450" as="geometry" />
        </mxCell>
        <mxCell id="verify" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" value="All four stages&#xa;within tolerance?" vertex="1">
          <mxGeometry height="100" width="180" x="410" y="555" as="geometry" />
        </mxCell>
        <mxCell id="calloop" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;align=center;" value="Sequentially calibrate PGA → BP → SUM → LP:&#xa;measure stage → estimate DC level → PI update → write DAC,&#xa;per stage until in-deadband and stable, or timeout&#xa;(Section III-B, Eq. 2–3)" vertex="1">
          <mxGeometry height="120" width="420" x="290" y="700" as="geometry" />
        </mxCell>
        <mxCell id="save" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="Save verified gain-dependent&#xa;DAC codes and CRC to EEPROM" vertex="1">
          <mxGeometry height="70" width="280" x="360" y="865" as="geometry" />
        </mxCell>
        <mxCell id="restore" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=13;" value="Restore acquisition routing and DFB coefficients;&#xa;freeze all DAC codes" vertex="1">
          <mxGeometry height="70" width="320" x="340" y="975" as="geometry" />
        </mxCell>
        <mxCell id="acquire" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" value="Acquire geophone signal&#xa;(calibration feedback inactive)" vertex="1">
          <mxGeometry height="80" width="200" x="100" y="970" as="geometry" />
        </mxCell>
        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=11;fontColor=#555555;align=left;spacingLeft=8;rotation=0;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;Orange: PSoC hardware   Blue: firmware/control&lt;br&gt;Red: DAC actuation/failure   Yellow: decision&lt;/font&gt;" vertex="1">
          <mxGeometry height="85" width="190" x="165" y="562.5" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="start" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" target="load">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="load" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" target="validrecord">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" edge="1" parent="1" source="verifycfg" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" target="verify">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" edge="1" parent="1" source="verify" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" target="restore" value="Yes">
          <mxGeometry relative="1" x="-0.94" y="10" as="geometry">
            <mxPoint as="offset" />
            <Array as="points">
              <mxPoint x="730" y="605" />
              <mxPoint x="730" y="1010" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e9" edge="1" parent="1" source="verify" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" target="calloop" value="No: recalibrate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" edge="1" parent="1" source="calloop" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" target="save">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" edge="1" parent="1" source="save" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" target="restore">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" edge="1" parent="1" source="restore" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" target="acquire">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
