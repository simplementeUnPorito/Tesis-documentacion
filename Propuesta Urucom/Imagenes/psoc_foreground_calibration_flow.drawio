<mxfile host="Electron" agent="Codex">
  <diagram id="psoc-calibration-flow" name="Foreground calibration flow">
    <mxGraphModel dx="857" dy="510" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="2000" math="1" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;" value="PSoC Foreground Per-Stage Calibration" vertex="1">
          <mxGeometry height="40" width="620" x="200" y="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#666666;" value="Controller-independent architecture; PI implementation shown" vertex="1">
          <mxGeometry height="30" width="520" x="250" y="70" as="geometry" />
        </mxCell>
        <mxCell id="start" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" value="Boot, PGA-gain change,&#xa;or calibration command" vertex="1">
          <mxGeometry height="80" width="200" x="410" y="120" as="geometry" />
        </mxCell>
        <mxCell id="load" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="Load EEPROM record for&#xa;selected PGA gain" vertex="1">
          <mxGeometry height="70" width="260" x="380" y="240" as="geometry" />
        </mxCell>
        <mxCell id="validrecord" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" value="Valid record&#xa;and CRC?" vertex="1">
          <mxGeometry height="100" width="180" x="420" y="350" as="geometry" />
        </mxCell>
        <mxCell id="applystored" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" value="Apply stored four-DAC code set" vertex="1">
          <mxGeometry height="70" width="250" x="750" y="425" as="geometry" />
        </mxCell>
        <mxCell id="seed" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" value="Apply safe nominal DAC seeds" vertex="1">
          <mxGeometry height="70" width="240" x="50" y="425" as="geometry" />
        </mxCell>
        <mxCell id="verifycfg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" value="Configure AMux + ADC + DFB&#xa;for rapid offset verification" vertex="1">
          <mxGeometry height="75" width="290" x="365" y="495" as="geometry" />
        </mxCell>
        <mxCell id="verify" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" value="All four stages&#xa;within tolerance?" vertex="1">
          <mxGeometry height="110" width="180" x="420" y="600" as="geometry" />
        </mxCell>
        <mxCell id="init" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="Select first stage&#xa;(PGA → BP → ADDER → LP)" vertex="1">
          <mxGeometry height="75" width="260" x="220" y="750" as="geometry" />
        </mxCell>
        <mxCell id="observe" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" value="Route stage through AMux; reset DFB history;&#xa;settle for a configurable number of samples" vertex="1">
          <mxGeometry height="85" width="330" x="185" y="865" as="geometry" />
        </mxCell>
        <mxCell id="estimate" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="Low-pass estimate DC level;&#xa;rescale ADC error to DAC domain" vertex="1">
          <mxGeometry height="75" width="280" x="210" y="990" as="geometry" />
        </mxCell>
        <mxCell id="deadband" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" value="Error inside&#xa;deadband?" vertex="1">
          <mxGeometry height="105" width="180" x="260" y="1105" as="geometry" />
        </mxCell>
        <mxCell id="control" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" value="Controller update&#xa;(implemented as PI)" vertex="1">
          <mxGeometry height="70" width="240" x="460" y="1277.5" as="geometry" />
        </mxCell>
        <mxCell id="limits" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="Apply sign and stage gain;&#xa;saturation + anti-windup + slew limit" vertex="1">
          <mxGeometry height="85" width="285" x="640" y="1125" as="geometry" />
        </mxCell>
        <mxCell id="writedac" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" value="Write selected stage DAC" vertex="1">
          <mxGeometry height="70" width="245" x="660" y="992.5" as="geometry" />
        </mxCell>
        <mxCell id="limit" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" value="Watchdog or stage&#xa;sample limit reached?" vertex="1">
          <mxGeometry height="110" width="185" x="690" y="852.5" as="geometry" />
        </mxCell>
        <mxCell id="failed" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" value="Report calibration failure;&#xa;do not overwrite valid EEPROM record" vertex="1">
          <mxGeometry height="75" width="260" x="652.5" y="750" as="geometry" />
        </mxCell>
        <mxCell id="stable" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" value="Inside same bucket for&#xa;configurable sample count?" vertex="1">
          <mxGeometry height="115" width="190" x="255" y="1255" as="geometry" />
        </mxCell>
        <mxCell id="refine" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="Try adjacent DAC code;&#xa;retain only if residual improves" vertex="1">
          <mxGeometry height="75" width="280" x="210" y="1410" as="geometry" />
        </mxCell>
        <mxCell id="more" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" value="More stages?" vertex="1">
          <mxGeometry height="95" width="160" x="270" y="1525" as="geometry" />
        </mxCell>
        <mxCell id="next" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="Select next stage" vertex="1">
          <mxGeometry height="65" width="180" x="260" y="1670" as="geometry" />
        </mxCell>
        <mxCell id="save" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="Save verified gain-dependent&#xa;DAC codes and CRC to EEPROM" vertex="1">
          <mxGeometry height="75" width="280" x="550" y="1535" as="geometry" />
        </mxCell>
        <mxCell id="restore" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=1;" value="Restore acquisition routing and DFB coefficients;&#xa;freeze all DAC codes" vertex="1">
          <mxGeometry height="85" width="320" x="530" y="1660" as="geometry" />
        </mxCell>
        <mxCell id="acquire" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" value="Acquire geophone signal&#xa;(calibration feedback inactive)" vertex="1">
          <mxGeometry height="80" width="200" x="590" y="1785" as="geometry" />
        </mxCell>
        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=11;fontColor=#555555;" value="&lt;font style=&quot;font-size: 13px;&quot;&gt;Orange: PSoC analog/digital hardware   Blue: firmware/control   Red: DAC actuation or failure   Yellow: decision&lt;/font&gt;" vertex="1">
          <mxGeometry height="105" width="325" x="525" y="1395" as="geometry" />
